# Postgres credentials
POSTGRES_HOST=<POSTGRES_HOST>
POSGRES_PORT=<POSGRES_PORT>
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=<POSTGRES_DB>

# Grafana
GF_SECURITY_ADMIN_USER=<GRAFANA_ADMIN>
GF_SECURITY_ADMIN_PASSWORD=<GRAFANA_PWD>

# Twelve-Data
TWELVEDATA_API_KEY=<TWELVEDATA_API_KEY>

# Azure IoT Hub Event Hubs Connection String
IOT_HUB_CONNECTION_STRING=<IOT_HUB_CONNECTION_STRING>
EVENTHUB_NAME=<EVENTHUB_NAME>
EVENTHUB_CONSUMER_GROUP=<EVENTHUB_CONSUMER_GROUP>
EVENTHUB_IGNORE_PAST=false
# EVENTHUB_IGNORE_PAST controls which events to read on startup:
#   false  = Resume from checkpoint offsets (or beginning if no checkpoint exists)
#   true   = Only read new events arriving after startup
#   full   = Read all events in hub (entire retention period)


# Azure container as CHECKPOINT_STORE
CHECKPOINT_STORE_CONNECTION_STRING=<CHECKPOINT_STORE_CONNECTION_STRING>
CHECKPOINT_STORE_CONTAINER_NAME=<CHECKPOINT_STORE_CONTAINER_NAME>
CHECKPOINT_UPDATE_FREQUENCY_MINUTES=30
# CHECKPOINT_UPDATE_FREQUENCY_MINUTES controls how often to write checkpoints to blob storage.
# Actual writes occur after batch processing when this interval has elapsed.
# Supports fractional values (e.g., 0.5 for 30 seconds, useful for testing).
# Pending checkpoints are always flushed on shutdown.


